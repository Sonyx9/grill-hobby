---
import type { Lang } from '../data/content';

interface Props {
  lang: Lang;
  nav: string[];
  sisterBrand: string;
  sisterBrandLink: string;
  sisterBrandHref?: string;
  logoSrc?: string;
}

const base = import.meta.env.BASE_URL;
const { lang, nav, sisterBrand, sisterBrandLink, sisterBrandHref = 'https://gardenandhobby.com', logoSrc = `${base}images/logo.png` } = Astro.props;

const navIds = ['curating', 'whats-coming', 'contact'];
const otherLang = lang === 'en' ? 'cz' : 'en';
const otherHref = lang === 'en' ? `${base}cz/` : base;
---

<header class="sticky top-0 z-50 bg-ivory/95 backdrop-blur-sm border-b border-accent/20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href={lang === 'en' ? base : `${base}cz/`} class="flex items-center shrink-0">
        <img src={logoSrc} alt="Grill & Hobby" class="h-[60px] md:h-[72px] w-auto" width="240" height="72" />
      </a>
      <nav class="flex items-center gap-4 md:gap-8" aria-label="Main">
        {nav.map((label, i) => (
          <a href={`#${navIds[i]}`} class="text-sm text-primary/90 hover:text-accent transition-colors">
            {label}
          </a>
        ))}
      </nav>
      <div class="flex items-center gap-6">
        <a
          href={otherHref}
          class="text-sm text-accent hover:text-accent-dark font-medium"
          aria-label={lang === 'en' ? 'Switch to Czech' : 'Přepnout na angličtinu'}
        >
          {lang === 'en' ? 'CZ' : 'EN'}
        </a>
      </div>
    </div>
    <div class="pb-2 pt-2 border-t border-accent/10 flex flex-wrap items-center justify-center gap-2">
      <span class="text-xs text-smoke">{sisterBrand}</span>
      <a
        href={sisterBrandHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs font-medium text-primary/80 hover:text-accent bg-primary/5 hover:bg-accent/10 px-3 py-1.5 rounded-full transition-colors"
      >
        {sisterBrandLink}
        <svg class="w-3 h-3 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</header>
