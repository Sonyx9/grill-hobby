---
interface Item {
  number: string;
  title: string;
  tagline: string;
  icon: 'line' | 'window' | 'eight' | 'seal' | 'globe' | 'logistics' | 'academy';
  sentence?: string;
}

interface Props {
  title: string;
  items: Item[];
}

const { title, items } = Astro.props;
---

<section id="whats-coming" class="py-24 md:py-32 bg-primary">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-semibold text-ivory text-center mb-20 md:mb-24">
      {title}
    </h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {items.map((item) => (
        <article class="group text-center p-8 rounded-xl border border-accent/30 bg-ivory/5 hover:bg-ivory/10 hover:border-accent/50 transition-all duration-300">
          <div class="flex justify-center mb-6 text-accent">
            {item.icon === 'line' && (
              <div class="w-16 h-16 rounded-full border-2 border-accent/60 flex items-center justify-center group-hover:border-accent group-hover:scale-105 transition-all">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden>
                  <path d="M12 3v18M3 12h18M8 8l8 8M16 8l-8 8" />
                </svg>
              </div>
            )}
            {item.icon === 'window' && (
              <div class="w-16 h-16 rounded-full border-2 border-accent/60 flex items-center justify-center group-hover:border-accent group-hover:scale-105 transition-all">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden>
                  <path d="M3 6h18v12H3V6zM3 10h18M10 3v18" />
                </svg>
              </div>
            )}
            {item.icon === 'eight' && (
              <div class="w-16 h-16 rounded-full border-2 border-accent/60 flex items-center justify-center group-hover:border-accent group-hover:scale-105 transition-all">
                <span class="font-display text-3xl font-semibold text-accent">8</span>
              </div>
            )}
            {item.icon === 'globe' && (
              <div class="w-16 h-16 rounded-full border-2 border-accent/60 flex items-center justify-center group-hover:border-accent group-hover:scale-105 transition-all" aria-hidden>
                <svg class="w-9 h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                  <circle cx="12" cy="12" r="2" fill="currentColor" />
                </svg>
              </div>
            )}
            {item.icon === 'logistics' && (
              <div class="w-16 h-16 rounded-full border-2 border-accent/60 flex items-center justify-center group-hover:border-accent group-hover:scale-105 transition-all" aria-hidden>
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="5" r="2.5" />
                  <circle cx="6" cy="12" r="2.5" />
                  <circle cx="18" cy="12" r="2.5" />
                  <circle cx="12" cy="19" r="2.5" />
                  <path d="M12 7.5v2M10 10.5l2 2 2-2M12 14.5v2" />
                </svg>
              </div>
            )}
            {item.icon === 'academy' && (
              <div class="w-16 h-16 rounded-lg border-2 border-accent/60 flex items-center justify-center group-hover:border-accent group-hover:scale-105 transition-all p-2" aria-hidden>
                <svg class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="1" />
                  <path d="M12 7c-2 1.5-3 4-3 6 0 2.5 1.5 4 3 5 1.5-1 3-2.5 3-5 0-2-1-4.5-3-6z" />
                </svg>
              </div>
            )}
            {item.icon === 'seal' && (
              <div class="w-16 h-16 rounded-full border-2 border-accent/60 flex items-center justify-center group-hover:border-accent group-hover:scale-105 transition-all">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
                  <path d="M12 2L15 8l6 1-4 4 1 6-6-3-6 3 1-6-4-4 6-1L12 2z" />
                </svg>
              </div>
            )}
          </div>
          <p class="font-display text-accent/80 text-xs font-semibold tracking-widest uppercase mb-2">{item.number}</p>
          <h3 class="font-display text-ivory text-lg font-semibold mb-2">{item.title}</h3>
          <p class="font-sans text-smoke text-sm leading-relaxed mb-3">{item.tagline}</p>
          {item.sentence && <p class="font-sans text-ivory/80 text-sm leading-relaxed">{item.sentence}</p>}
        </article>
      ))}
    </div>
  </div>
</section>
