---
interface Props {
  text: string;
  subtext: string;
  cta: string;
  ctaHref: string;
}

const { text, subtext, cta, ctaHref } = Astro.props;
---

<section class="py-20 md:py-28 bg-ivory border-t border-accent/20">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="font-display text-2xl md:text-3xl text-primary mb-4">
      {text}
    </p>
    <p class="font-sans text-primary/80 text-lg mb-10">
      {subtext}
    </p>
    <a
      href={ctaHref}
      target="_blank"
      rel="noopener noreferrer"
      class="group inline-flex items-center gap-3 px-8 py-4 bg-primary text-ivory font-sans text-sm font-medium tracking-wide uppercase rounded-full hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-ivory transition-all duration-200 shadow-md hover:shadow-lg"
    >
      {cta}
      <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>
