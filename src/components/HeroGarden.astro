---
interface Props {
  headline: string;
  subheadline: string;
}

const { headline, subheadline } = Astro.props;
---

<section class="relative min-h-[85vh] flex flex-col justify-end pb-16 md:pb-24">
  <img
    src={`${import.meta.env.BASE_URL}images/hero-grill.jpg`}
    alt=""
    class="absolute inset-0 w-full h-full object-cover object-center -z-10"
    loading="eager"
    fetchpriority="high"
    width="1920"
    height="1080"
  />
  <div class="absolute inset-0 -z-[5] bg-primary/60" aria-hidden />
  <div class="absolute inset-0 -z-[4] bg-gradient-to-t from-primary via-primary/40 to-transparent" aria-hidden />
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="max-w-2xl">
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold text-ivory leading-tight mb-6 drop-shadow-[0_2px_8px_rgba(0,0,0,0.7)]">
        {headline}
      </h1>
      <p class="font-sans text-lg md:text-xl text-ivory max-w-xl drop-shadow-[0_1px_4px_rgba(0,0,0,0.8)]">
        {subheadline}
      </p>
    </div>
  </div>
</section>
