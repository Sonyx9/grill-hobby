---
interface Props {
  title?: string;
  description?: string;
  email?: string;
  phone?: string;
}

const { 
  title = 'Kontakt',
  description = '',
  email = 'pecimichal@gmail.com',
  phone = '+420 731 000 307',
} = Astro.props;

const mailtoSubject = encodeURIComponent('E-shop – dotaz');
const mailtoHref = `mailto:${email}?subject=${mailtoSubject}`;
const telHref = `tel:${phone.replace(/\s/g, '')}`;
---

<section id="kontakt" class="py-16 md:py-24 bg-neutral-cream">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-primary mb-4">
        {title}
      </h2>
      {description && (
        <p class="text-primary/80 text-lg">
          {description}
        </p>
      )}
    </div>

    <p class="text-primary/80 text-lg text-center mb-12 max-w-2xl mx-auto">
      Zajímá vás více o našich prémiových grilech nebo sortimentu zahradního nářadí?
      Neváhejte nás kontaktovat. Každému dotazu věnujeme individuální pozornost.
    </p>

    <div class="flex flex-col sm:flex-row gap-8 justify-center items-center">
      <a 
        href={telHref}
        class="flex items-center gap-4 px-8 py-4 bg-primary text-white rounded-md hover:bg-primary-light transition-colors font-semibold"
      >
        <svg class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span>{phone}</span>
      </a>
      <a 
        href={mailtoHref}
        class="flex items-center gap-4 px-8 py-4 border-2 border-primary text-primary rounded-md hover:bg-primary hover:text-white transition-colors font-semibold"
      >
        <svg class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <span>{email}</span>
      </a>
    </div>
  </div>
</section>
