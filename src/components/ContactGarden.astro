---
interface Props {
  title: string;
  text: string;
  email: string;
  phone: string;
}

const { title, text, email, phone } = Astro.props;

const mailtoSubject = encodeURIComponent('Grill & Hobby – inquiry');
const mailtoHref = `mailto:${email}?subject=${mailtoSubject}`;
const telHref = `tel:${phone.replace(/\s/g, '')}`;
---

<section id="contact" class="py-20 md:py-28 bg-primary">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-display text-3xl md:text-4xl font-semibold text-ivory mb-6">
      {title}
    </h2>
    <p class="font-sans text-ivory/90 text-lg leading-relaxed mb-12">
      {text}
    </p>
    <div class="flex flex-col sm:flex-row gap-6 justify-center">
      <a
        href={telHref}
        class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-accent text-primary font-sans font-medium rounded-sm hover:bg-accent-light transition-colors"
      >
        <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {phone}
      </a>
      <a
        href={mailtoHref}
        class="inline-flex items-center justify-center gap-3 px-8 py-4 border-2 border-accent text-ivory font-sans font-medium rounded-sm hover:bg-accent/20 transition-colors"
      >
        <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {email}
      </a>
    </div>
  </div>
</section>
