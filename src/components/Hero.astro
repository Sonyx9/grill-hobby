---
interface Props {
  title?: string;
  perex?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { 
  title = 'Nová kapitola venkovního života.',
  perex = 'Dva specializované e-shopy.\nGrilování a zahrada v té nejlepší podobě.',
  ctaText = 'Kontaktujte nás',
  ctaHref = '#kontakt'
} = Astro.props;
---

<section class="relative min-h-[70vh] flex flex-col overflow-hidden">
  <!-- Background image -->
  <img
    src={`${import.meta.env.BASE_URL}images/hero-bg.jpg`}
    alt=""
    class="absolute inset-0 w-full h-full object-cover object-center -z-10"
    loading="eager"
    fetchpriority="high"
    width="1920"
    height="1080"
  />
  
  <!-- Overlay pro čitelnost textu -->
  <div 
    class="absolute inset-0 -z-[5] bg-gradient-to-b from-black/50 via-black/60 to-black/70"
    aria-hidden="true"
  />

  <!-- Nav -->
  <nav class="relative pt-6 md:pt-10 px-4 sm:px-6 lg:px-12 flex justify-center items-center gap-8 md:gap-12" aria-label="Hlavní navigace">
    <a href={import.meta.env.BASE_URL} class="flex items-center">
      <img src={`${import.meta.env.BASE_URL}images/logo.png`} alt="G&H Grill and Hobby" class="h-16 md:h-20 w-auto" width="240" height="80" />
    </a>
    <a href="#co-chystame" class="text-sm md:text-base text-white hover:text-accent transition-colors">Co chystáme</a>
    <a href="#uvod" class="text-sm md:text-base text-white hover:text-accent transition-colors">O nás</a>
    <a 
      href="#kontakt"
      class="px-6 py-3 bg-accent text-primary font-semibold rounded-md hover:bg-accent-light transition-colors shadow-lg ring-2 ring-accent/50"
    >
      Kontakt
    </a>
  </nav>

  <!-- Main content - centered -->
  <div class="relative flex-1 flex items-center justify-center px-4 sm:px-6 lg:px-12 py-16 md:py-24 pb-24 md:pb-32">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 md:mb-8">
        {title}
      </h1>
      <p class="text-lg md:text-xl text-white/95 mb-10 md:mb-12 max-w-2xl mx-auto leading-relaxed whitespace-pre-line">
        {perex}
      </p>
      <a 
        href={ctaHref}
        class="inline-flex justify-center items-center px-8 py-4 bg-accent text-primary font-semibold rounded-md hover:bg-accent-light transition-colors"
      >
        {ctaText}
      </a>
    </div>
  </div>
</section>
